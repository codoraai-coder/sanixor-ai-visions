# ════════════════════════════════════════════════════════════════
#  Sanixor Website — Frontend Environment
#  Copy to `.env` (or `.env.local`) and adjust for your environment.
#  Only VITE_-prefixed vars are exposed to the browser build.
# ════════════════════════════════════════════════════════════════

# Base URL of the Sanixor backend API (no trailing slash).
#   • Local backend:  http://localhost:8787
#   • Production:      https://api.sanixor.space   (default if unset)
VITE_API_BASE_URL=http://localhost:8787
